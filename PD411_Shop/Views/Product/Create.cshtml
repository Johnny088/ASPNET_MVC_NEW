@model CreateProductVM;

<div class="d-flex justify-content-center w-100  m-auto">
<form class="w-50" 
method="post" 
asp-controller="Product" 
asp-action="Create"
enctype="multipart/form-data">

    <fieldset>
        <div>
            <label for="name" class="form-label mt-4">Name</label>
            <input type="text" class="form-control" id="name" name="name" placeholder="Enter the name">
            <small hidden  class="form-text text-muted">We'll never share your email with anyone else.</small>
        </div>
            <div>
                <label for="description" class="form-label mt-4"> Product description</label>
                <textarea class="form-control" id="description" name="description" placeholder="Enter the product's description" rows="3"></textarea>
            </div>
        <div>
            <label for="price" class="form-label mt-4">Price</label>
            <input type="number" class="form-control" id="price" name="price" placeholder="Enter the price">
            <small hidden  class="form-text text-muted">We'll never share your email with anyone else.</small>
        </div>
        <div>
            <label for="image" class="form-label mt-4">Image</label>
            <input accept="image/*" type="file" class="form-control" id="image" name="image" placeholder="put the image">
            <small hidden  class="form-text text-muted">We'll never share your email with anyone else.</small>
        </div>
        <div>
            <label for="amount" class="form-label mt-4">Number of products</label>
            <input type="number" class="form-control" id="amount" name="amount" placeholder="Enter number of the pruducts">
            <small hidden  class="form-text text-muted">We'll never share your email with anyone else.</small>
        </div>
        <div>
            <label for="color" class="form-label mt-4">Color</label>
            <input type="text" class="form-control" id="color" name="color" placeholder="Enter the color">
            <small hidden  class="form-text text-muted">We'll never share your email with anyone else.</small>
        </div>
        <div class="mb-3">
            <label for="category" class="form-label mt-4">Category is in process...</label>
            <input type="text" class="form-control" id="category" placeholder="Enter the category">
            <small hidden  class="form-text text-muted">We'll never share your email with anyone else.</small>
        </div>
        <div class="text-center">
            <input class="btn btn-success w-25" type="submit" value="Add"/>
            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-danger w-25">Back</a>
        </div>
    </fieldset>
</form>
</div>