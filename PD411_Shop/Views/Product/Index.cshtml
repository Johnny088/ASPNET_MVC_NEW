@model IEnumerable<ProductModel>
@{
    ViewData["Title"] = "Products";
}
<div class="text-center">
    <table class="table table-striped align-middle">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Price</th>
                <th>Color</th>
                <th>Description</th>
                <th>Image</th>
                <th>Created Data</th>
                <th>
                    <a asp-action="Create" asp-controller="Product" style="color: white">
                        <i class="bi bi-plus-circle-dotted"></i>
                    </a>
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>@product.Id</td>
                    <td>@product.Name</td>
                    <td>@product.Price</td>
                    <td>@product.Color</td>
                    <td>@product.Description</td>
                    <td><img class="image-scale" height="50" src="~/images/@(product.Image ?? "default.webp")" alt="@product.Name" /></td>
                    <td>@product.CreatedDate.ToString("dd.mm.yyyy")</td>
                    <td><a asp-controller="Product" asp-action="Delete" asp-route-id="@product.Id"><i class="bi bi-trash3-fill" style="color: red"></i></a></td>
                </tr>

            }
        </tbody>
    </table>
</div>
