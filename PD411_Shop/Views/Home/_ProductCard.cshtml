@model ProductModel

<div class="card m-1" style="width: 18rem;">
    <img height="200" width="200" style="object-fit: contain" src="~/images/@(Model.Image ?? "default.webp")" class="card-img-top" alt="@Model.Name">
    <div class="card-body">
        <h5 class="card-title">@Model.Name</h5>
        <p class="card-text">$@Model.Price</p>
        <a href="#" class="btn btn-primary">View more</a>
    </div>
</div>